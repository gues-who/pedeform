# ── Pedeform API — copie para .env e preencha ────────────────────────────────

# Porta do servidor HTTP/WebSocket
PORT=3001

# Origens CORS aceitas (separar por vírgula para múltiplas)
CORS_ORIGIN=http://localhost:3000

# ── Banco de dados (pendente — mock in-memory por enquanto) ──────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/pedeform
# MONGODB_URI=mongodb://localhost:27017/pedeform

# ── Stripe (pendente) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── AWS (pendente) ───────────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
