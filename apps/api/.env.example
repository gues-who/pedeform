# Porta HTTP + WebSocket (Socket.IO). Next.js costuma usar 3000 em dev.
PORT=3001

# Origens permitidas (REST e Socket.IO), separadas por vírgula.
# Ex.: front local + preview Vercel
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (pedidos, cardápio, pagamentos)
DATABASE_URL=postgresql://user:password@localhost:5432/pedeform

# MongoDB (perfil VIP / histórico flexível)
MONGODB_URI=mongodb://localhost:27017/pedeform

# Stripe — servidor (NUNCA expor no front-end)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Opcional: ID da conta conectada / país para Apple Pay / Google Pay
# STRIPE_ACCOUNT_COUNTRY=BR
