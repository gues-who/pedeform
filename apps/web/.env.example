# ── Pedeform Web — copie para .env.local e preencha ─────────────────────────

# URL base da API (browser). No localhost, deixe em branco para usar o proxy
# /api do Next (evita "Failed to fetch" entre portas 3000 e 3001).
# NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# URL do servidor WebSocket (Socket.IO)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# URL da API para server components (server-side fetch, não exposta ao browser)
API_BASE_URL=http://localhost:3001/v1

# ── Firebase (Auth + Firestore + Analytics no browser) ───────────────────────
# Copie do console: Project settings → Your apps → SDK setup.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Stripe (pendente) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Produção ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.pedeform.com/v1
# NEXT_PUBLIC_WS_URL=https://api.pedeform.com
# API_BASE_URL=https://api.pedeform.com/v1
