# ═══════════════════════════════════════════════════════════════════════════════
# Pedeform — Web (Next.js)
# Copie este arquivo:  cp apps/web/.env.example apps/web/.env.local
# Preencha e reinicie:  npm run dev
# O next.config também lê .env.local na RAIZ do monorepo (opcional).
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Nest (localhost) ───────────────────────────────────────────────────────
# Browser: deixe NEXT_PUBLIC_API_URL vazio para usar o rewrite /api → Nest :3001
# NEXT_PUBLIC_API_URL=http://localhost:3001/v1

NEXT_PUBLIC_WS_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001/v1

# ── Firebase (Auth + Firestore no cliente) ───────────────────────────────────
# Console: https://console.firebase.google.com → seu projeto → ⚙️ Configurações
# → Seus apps → app Web (</>) → SDK setup (npm) — copie o objeto firebaseConfig.
#
# Campos obrigatórios para o app inicializar (firebase.ts) — copie do Console, não commite:
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Realtime Database (só se usar RTDB; vem do firebaseConfig como databaseURL)
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://SEU-PROJETO-default-rtdb.firebaseio.com

# Analytics (measurementId no Console; opcional)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Produção / Vercel (exemplo) ──────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://sua-api.com/v1
# NEXT_PUBLIC_WS_URL=https://sua-api.com
# API_BASE_URL=https://sua-api.com/v1
# API_PROXY_TARGET=https://sua-api.com   # destino do rewrite /api no next.config

# ── Stripe (quando existir) ────────────────────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
